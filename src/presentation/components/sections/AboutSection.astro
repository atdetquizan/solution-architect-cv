---
import type { Profile } from '@domain/entities/Profile';
import type { AboutSectionContent } from '@domain/entities/SectionContent';
import SectionContainer from '@presentation/components/ui/SectionContainer.astro';
import SectionTitle from '@presentation/components/ui/SectionTitle.astro';

interface Props {
  profile: Profile;
  content: AboutSectionContent;
}

const { profile, content } = Astro.props;
---

<SectionContainer id="about">
  <SectionTitle eyebrow={content.eyebrow} title={content.title} description={content.description || profile.summary} />
  <div class="grid gap-5 md:grid-cols-3">
    <article class="card-enterprise group rounded-xl border border-(--line) bg-(--panel) p-6">
      <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-(--accent)/10">
        <svg class="h-5 w-5 text-(--accent)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
        </svg>
      </div>
      <h3 class="font-subtitle text-lg text-(--text-primary)">{content.architectureMindsetTitle}</h3>
      <div class="mt-2 h-0.5 w-8 rounded bg-(--accent) opacity-60"></div>
      <p class="mt-3 text-sm leading-relaxed text-(--text-secondary)">{profile.architectureMindset}</p>
    </article>
    <article class="card-enterprise group rounded-xl border border-(--line) bg-(--panel) p-6">
      <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-(--accent)/10">
        <svg class="h-5 w-5 text-(--accent)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z" />
        </svg>
      </div>
      <h3 class="font-subtitle text-lg text-(--text-primary)">{content.enterpriseExperienceTitle}</h3>
      <div class="mt-2 h-0.5 w-8 rounded bg-(--accent) opacity-60"></div>
      <p class="mt-3 text-sm leading-relaxed text-(--text-secondary)">{profile.enterpriseExperience}</p>
    </article>
    <article class="card-enterprise group rounded-xl border border-(--line) bg-(--panel) p-6">
      <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-(--accent)/10">
        <svg class="h-5 w-5 text-(--accent)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
        </svg>
      </div>
      <h3 class="font-subtitle text-lg text-(--text-primary)">{content.leadershipExperienceTitle}</h3>
      <div class="mt-2 h-0.5 w-8 rounded bg-(--accent) opacity-60"></div>
      <p class="mt-3 text-sm leading-relaxed text-(--text-secondary)">{profile.leadershipExperience}</p>
    </article>
  </div>
</SectionContainer>
