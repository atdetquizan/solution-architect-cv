---
import type { Profile } from '@domain/entities/Profile';
import type { HeroSectionContent } from '@domain/entities/SectionContent';
import ButtonLink from '@presentation/components/ui/ButtonLink.astro';
import SectionContainer from '@presentation/components/ui/SectionContainer.astro';
import { withBaseUrl } from '@shared/utils/withBaseUrl';

interface Props {
  profile: Profile;
  content: HeroSectionContent;
}

const { profile, content } = Astro.props;

const expertiseImages = [
  {
    src: '/images/cloud-architecture.png',
    alt: content.cloudArchitectureAlt,
    label: content.cloudArchitectureLabel,
  },
  {
    src: '/images/enterprise-infrastructure.png',
    alt: content.enterpriseInfrastructureAlt,
    label: content.enterpriseInfrastructureLabel,
  },
  {
    src: '/images/distributed-systems.png',
    alt: content.distributedSystemsAlt,
    label: content.distributedSystemsLabel,
  }
];
---

<SectionContainer id="hero" className="max-w-7xl pt-20 sm:pt-24 md:pt-28">
  <div class="grid items-center gap-8 sm:gap-10 md:gap-14 md:grid-cols-[1.08fr_0.92fr]">
    <div>
      <div class="flex items-center gap-3">
        <span class="h-px w-8 bg-(--accent) opacity-70"></span>
        <p class="text-[0.65rem] font-semibold tracking-[0.26em] text-(--accent) uppercase sm:text-xs sm:tracking-[0.35em]">{content.eyebrow}</p>
      </div>
      <h1 class="mt-4 font-title text-[clamp(2.4rem,12vw,5.8rem)] leading-[0.88] text-(--text-primary)">{profile.name}</h1>
      <p class="mt-3 font-subtitle text-[1.18rem] text-(--accent-soft) sm:text-[1.45rem] md:mt-4 md:text-[2rem]">{profile.role}</p>
      <p class="mt-4 max-w-xl text-[0.96rem] leading-relaxed text-(--text-secondary) sm:mt-5 sm:text-lg">{profile.tagline}</p>
      <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
        <ButtonLink href="#projects" label={content.primaryCtaLabel} />
        <ButtonLink href="#contact" label={content.secondaryCtaLabel} variant="secondary" />
      </div>
    </div>
    <div class="relative mt-1 md:mt-0 md:row-span-2">
      <div class="relative mx-auto w-fit">
        <div class="absolute inset-1 -z-10 rounded-full bg-[radial-gradient(circle,rgba(130,186,255,0.9),rgba(41,91,170,0.5),transparent_74%)] blur-3xl"></div>
        <div class="absolute -inset-3 -z-10 rounded-full bg-[radial-gradient(circle,rgba(255,224,160,0.58),rgba(255,224,160,0.05)_64%,transparent_76%)] blur-xl"></div>
        <img
          src={withBaseUrl(profile.profileImage)}
          alt={`Foto de perfil de ${profile.name}`}
          width="384"
          height="384"
          class="mx-auto aspect-square w-[min(22.5rem,88vw)] scale-[1.2] object-contain drop-shadow-[0_26px_70px_rgba(19,52,99,0.34)] sm:w-108 sm:scale-[1.33] md:w-136 md:scale-[1.55]"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </div>
    </div>
    <div class="md:col-start-1 md:row-start-2 md:self-start">
      <div class="h-px w-full max-w-md bg-linear-to-r from-(--line-strong) to-transparent"></div>
      <p class="mt-4 text-[0.68rem] font-medium tracking-[0.18em] text-(--text-secondary) uppercase opacity-60 sm:text-xs sm:tracking-[0.2em]">Areas de especializacion</p>
      <div class="mt-4 grid max-w-lg gap-3 sm:gap-4 sm:grid-cols-3">
        {
          expertiseImages.map((image) => (
            <figure class="group relative overflow-hidden rounded-xl border border-(--line) bg-(--panel) p-3 backdrop-blur-sm transition-all duration-300 hover:border-(--accent)/40 hover:shadow-[0_4px_20px_rgba(36,59,90,0.10)]">
              <div class="flex h-28 items-center justify-center overflow-hidden sm:h-36">
                <img
                  src={withBaseUrl(image.src)}
                  alt={image.alt}
                  width="280"
                  height="180"
                  class="h-full w-full object-contain transition-transform duration-500 group-hover:scale-[1.05]"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <figcaption class="mt-2 text-center text-[0.64rem] font-semibold tracking-widest text-(--text-secondary) uppercase transition-colors duration-300 group-hover:text-(--accent) sm:text-xs sm:tracking-[0.12em]">
                {image.label}
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </div>
</SectionContainer>
