---
import type { Project } from '@domain/entities/Project';
import type { SectionHeaderContent } from '@domain/entities/SectionContent';
import Card from '@presentation/components/ui/Card.astro';
import SectionContainer from '@presentation/components/ui/SectionContainer.astro';
import SectionTitle from '@presentation/components/ui/SectionTitle.astro';
import Tag from '@presentation/components/ui/Tag.astro';

interface Props {
  items: Project[];
  content: SectionHeaderContent;
}

const { items, content } = Astro.props;
---

<SectionContainer id="projects">
  <SectionTitle eyebrow={content.eyebrow} title={content.title} description={content.description} />
  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
    {items.map((item) => (
      <Card title={item.name} subtitle={item.focus}>
        <p>{item.description}</p>
        <div class="mt-4 flex flex-wrap gap-2">
          {item.stack.map((tech) => (
            <Tag text={tech} />
          ))}
        </div>
      </Card>
    ))}
  </div>
</SectionContainer>
