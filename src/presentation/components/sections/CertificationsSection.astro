---
import type { Certification } from '@domain/entities/Certification';
import type { SectionHeaderContent } from '@domain/entities/SectionContent';
import SectionContainer from '@presentation/components/ui/SectionContainer.astro';
import SectionTitle from '@presentation/components/ui/SectionTitle.astro';

interface Props {
  items: Certification[];
  content: SectionHeaderContent;
}

const { items, content } = Astro.props;
---

<SectionContainer id="certifications">
  <SectionTitle eyebrow={content.eyebrow} title={content.title} description={content.description} />
  <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
    {items.map((item) => (
      <article class="card-enterprise flex flex-col gap-3 rounded-xl border border-(--line) bg-(--panel) p-4 sm:p-5">
        <div class="flex items-start justify-between gap-3">
          <h3 class="font-subtitle text-base leading-snug text-(--text-primary)">{item.title}</h3>
          <span class="mt-0.5 shrink-0 rounded-full border border-(--accent)/30 bg-(--accent)/10 px-2.5 py-0.5 text-xs font-bold tracking-wider text-(--accent)">{item.year}</span>
        </div>
        <div class="flex items-center gap-2 text-sm text-(--text-secondary)">
          <svg class="h-3.5 w-3.5 shrink-0 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />
          </svg>
          <span>{item.issuer}</span>
        </div>
      </article>
    ))}
  </div>
</SectionContainer>
