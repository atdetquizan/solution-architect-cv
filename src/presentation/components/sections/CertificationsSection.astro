---
import type { Certification } from '@domain/entities/Certification';
import SectionContainer from '@presentation/components/ui/SectionContainer.astro';
import SectionTitle from '@presentation/components/ui/SectionTitle.astro';

interface Props {
  items: Certification[];
}

const { items } = Astro.props;
---

<SectionContainer id="certifications">
  <SectionTitle eyebrow="Credentials" title="Certifications" description="Validated expertise across AWS, Azure, Kubernetes, and cloud architecture domains." />
  <div class="grid gap-4 md:grid-cols-2">
    {items.map((item) => (
      <article class="rounded-xl border border-[var(--line)] bg-[var(--panel)] p-5">
        <h3 class="font-subtitle text-xl">{item.title}</h3>
        <p class="mt-2 text-sm text-[var(--text-secondary)]">{item.issuer}</p>
        <p class="mt-2 text-xs tracking-[0.15em] text-[var(--accent)] uppercase">{item.year}</p>
      </article>
    ))}
  </div>
</SectionContainer>
