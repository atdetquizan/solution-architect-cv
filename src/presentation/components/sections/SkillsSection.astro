---
import type { SkillCategory } from '@domain/entities/Skill';
import type { SectionHeaderContent } from '@domain/entities/SectionContent';
import SectionContainer from '@presentation/components/ui/SectionContainer.astro';
import SectionTitle from '@presentation/components/ui/SectionTitle.astro';
import Tag from '@presentation/components/ui/Tag.astro';

interface Props {
  items: SkillCategory[];
  content: SectionHeaderContent;
}

const { items, content } = Astro.props;
---

<SectionContainer id="skills">
  <SectionTitle eyebrow={content.eyebrow} title={content.title} description={content.description} />
  <div class="grid gap-3.5 sm:grid-cols-2 sm:gap-4 lg:grid-cols-3">
    {items.map((item) => (
      <article class="card-enterprise rounded-xl border border-(--line) bg-(--panel) p-4 sm:p-5">
        <div class="flex items-start justify-between gap-2">
          <h3 class="font-subtitle text-base text-(--text-primary)">{item.category}</h3>
          <span class="mt-0.5 shrink-0 rounded-full bg-(--accent)/15 px-2 py-0.5 text-xs font-semibold text-(--accent)">{item.skills.length}</span>
        </div>
        <div class="mt-3 flex flex-wrap gap-1.5 sm:gap-2">
          {item.skills.map((skill) => (
            <Tag text={skill} />
          ))}
        </div>
      </article>
    ))}
  </div>
</SectionContainer>
