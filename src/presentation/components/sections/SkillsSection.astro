---
import type { SkillCategory } from '@domain/entities/Skill';
import SectionContainer from '@presentation/components/ui/SectionContainer.astro';
import SectionTitle from '@presentation/components/ui/SectionTitle.astro';
import Tag from '@presentation/components/ui/Tag.astro';

interface Props {
  items: SkillCategory[];
}

const { items } = Astro.props;
---

<SectionContainer id="skills">
  <SectionTitle eyebrow="Capabilities" title="Technical skills" description="A pragmatic stack for enterprise architecture and platform scalability." />
  <div class="grid gap-4 md:grid-cols-2">
    {items.map((item) => (
      <article class="rounded-xl border border-[var(--line)] bg-[var(--panel)] p-5">
        <h3 class="font-subtitle text-xl">{item.category}</h3>
        <div class="mt-4 flex flex-wrap gap-2">
          {item.skills.map((skill) => (
            <Tag text={skill} />
          ))}
        </div>
      </article>
    ))}
  </div>
</SectionContainer>
