---
import type { ContactInfo } from '@domain/entities/Contact';
import type { ContactSectionContent } from '@domain/entities/SectionContent';
import ButtonLink from '@presentation/components/ui/ButtonLink.astro';
import SectionContainer from '@presentation/components/ui/SectionContainer.astro';
import SectionTitle from '@presentation/components/ui/SectionTitle.astro';
import { withBaseUrl } from '@shared/utils/withBaseUrl';

interface Props {
  contact: ContactInfo;
  content: ContactSectionContent;
}

const { contact, content } = Astro.props;
---

<SectionContainer id="contact" className="pb-16 sm:pb-20">
  <SectionTitle eyebrow={content.eyebrow} title={content.title} description={content.description} />
  <div class="rounded-2xl border border-(--line) bg-(--panel) p-5 sm:p-6 md:p-8">
    <div class="grid gap-7 md:grid-cols-2 md:gap-10">
      <div>
        <p class="mb-4 text-xs font-semibold tracking-[0.2em] text-(--accent) uppercase opacity-70">Información de contacto</p>
        <ul class="space-y-3">
          <li class="flex items-center gap-3 text-sm">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-(--accent)/10">
              <svg class="h-4 w-4 text-(--accent)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
            </span>
            <div>
              <p class="text-xs text-(--text-secondary) opacity-70">{content.emailLabel}</p>
              <a href={`mailto:${contact.email}`} class="break-all font-medium text-(--text-primary) transition-colors hover:text-(--accent)">{contact.email}</a>
            </div>
          </li>
          <li class="flex items-center gap-3 text-sm">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-(--accent)/10">
              <svg class="h-4 w-4 text-(--accent)" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" /></svg>
            </span>
            <div>
              <p class="text-xs text-(--text-secondary) opacity-70">{content.githubLabel}</p>
              <a href={contact.github} target="_blank" rel="noopener noreferrer" class="break-all font-medium text-(--text-primary) transition-colors hover:text-(--accent)">{contact.github.replace('https://', '')}</a>
            </div>
          </li>
          <li class="flex items-center gap-3 text-sm">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-(--accent)/10">
              <svg class="h-4 w-4 text-(--accent)" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </span>
            <div>
              <p class="text-xs text-(--text-secondary) opacity-70">{content.linkedinLabel}</p>
              <a href={contact.linkedin} target="_blank" rel="noopener noreferrer" class="break-all font-medium text-(--text-primary) transition-colors hover:text-(--accent)">{contact.linkedin.replace('https://', '')}</a>
            </div>
          </li>
        </ul>
      </div>
      <div class="flex flex-col justify-center gap-3 border-t border-(--line) pt-6 md:border-t-0 md:border-l md:pt-0 md:pl-10">
        <p class="text-xs font-semibold tracking-[0.2em] text-(--accent) uppercase opacity-70">Conectemos</p>
        <p class="text-sm text-(--text-secondary)">¿Tienes un proyecto o una oportunidad? Escríbeme directamente.</p>
        <div class="mt-2 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <ButtonLink href={contact.linkedin} label={content.linkedinLabel} variant="secondary" />
          <ButtonLink href={contact.github} label={content.githubLabel} variant="secondary" />
          <ButtonLink href={withBaseUrl(contact.cvUrl)} label={content.downloadCvLabel} />
        </div>
      </div>
    </div>
  </div>
</SectionContainer>
