---
import type { ContactInfo } from '@domain/entities/Contact';
import ButtonLink from '@presentation/components/ui/ButtonLink.astro';
import SectionContainer from '@presentation/components/ui/SectionContainer.astro';
import SectionTitle from '@presentation/components/ui/SectionTitle.astro';
import { withBaseUrl } from '@shared/utils/withBaseUrl';

interface Props {
  contact: ContactInfo;
}

const { contact } = Astro.props;
---

<SectionContainer id="contact" className="pb-20">
  <SectionTitle eyebrow="Connect" title="Let’s build architecture that scales" description="Open to enterprise architecture advisory, platform modernization, and leadership opportunities." />
  <div class="grid gap-4 rounded-2xl border border-[var(--line)] bg-[var(--panel)] p-6 md:grid-cols-2 md:p-8">
    <div class="space-y-2 text-sm">
      <p><span class="text-[var(--accent)]">Email:</span> <a href={`mailto:${contact.email}`} class="text-[var(--text-primary)] hover:text-[var(--accent)]">{contact.email}</a></p>
      <p><span class="text-[var(--accent)]">GitHub:</span> <a href={contact.github} class="text-[var(--text-primary)] hover:text-[var(--accent)]">{contact.github}</a></p>
      <p><span class="text-[var(--accent)]">LinkedIn:</span> <a href={contact.linkedin} class="text-[var(--text-primary)] hover:text-[var(--accent)]">{contact.linkedin}</a></p>
    </div>
    <div class="flex items-center gap-4">
      <ButtonLink href={contact.linkedin} label="LinkedIn" variant="secondary" />
      <ButtonLink href={contact.github} label="GitHub" variant="secondary" />
      <ButtonLink href={withBaseUrl(contact.cvUrl)} label="Download CV" />
    </div>
  </div>
</SectionContainer>
