---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<header class="mb-10 max-w-3xl">
  <div class="flex items-center gap-3">
    <span class="h-px w-6 bg-(--accent) opacity-70"></span>
    <p class="text-xs font-semibold tracking-[0.3em] text-(--accent) uppercase">{eyebrow}</p>
  </div>
  <h2 class="mt-3 font-title text-4xl leading-none text-(--text-primary) md:text-5xl">{title}</h2>
  {description && <p class="mt-4 text-base text-(--text-secondary) md:text-lg">{description}</p>}
</header>
