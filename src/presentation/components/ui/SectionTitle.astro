---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<header class="mb-10 max-w-3xl">
  <p class="tracking-[0.2em] text-[var(--accent)] uppercase">{eyebrow}</p>
  <h2 class="mt-3 font-title text-4xl leading-none text-[var(--text-primary)] md:text-5xl">{title}</h2>
  {description && <p class="mt-4 text-base text-[var(--text-secondary)] md:text-lg">{description}</p>}
</header>
