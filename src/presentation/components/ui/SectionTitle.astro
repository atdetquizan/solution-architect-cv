---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<header class="mb-8 max-w-3xl md:mb-10">
  <div class="flex items-center gap-3">
    <span class="h-px w-6 bg-(--accent) opacity-70"></span>
    <p class="text-[0.68rem] font-semibold tracking-[0.22em] text-(--accent) uppercase sm:text-xs sm:tracking-[0.3em]">{eyebrow}</p>
  </div>
  <h2 class="mt-3 font-title text-[clamp(2rem,10.5vw,3.3rem)] leading-[0.95] text-(--text-primary)">{title}</h2>
  {description && <p class="mt-4 text-sm leading-relaxed text-(--text-secondary) sm:text-base md:text-lg">{description}</p>}
</header>
