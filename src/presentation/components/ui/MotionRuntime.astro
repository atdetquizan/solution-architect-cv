<script>
  let lastScrollY = 0;

  const tagSectionChildren = (section: HTMLElement) => {
    if (section.dataset.motionTagged === 'true') return;

    const children = Array.from(section.children) as HTMLElement[];
    children.forEach((child, index) => {
      child.classList.add('motion-child');
      child.style.setProperty('--child-index', String(index));
    });

    section.dataset.motionTagged = 'true';
  };

  const setupRevealSections = () => {
    const sections = Array.from(document.querySelectorAll<HTMLElement>('.reveal-section'));
    if (!sections.length) return;

    sections.forEach((section, index) => {
      section.style.setProperty('--reveal-delay', `${Math.min(index * 55, 280)}ms`);
      tagSectionChildren(section);
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      {
        threshold: 0.15,
        rootMargin: '0px 0px -12% 0px'
      }
    );

    sections.forEach((section) => observer.observe(section));
  };

  const setupLazyImageReveal = () => {
    const images = Array.from(document.querySelectorAll<HTMLImageElement>('img[loading="lazy"]'));
    if (!images.length) return;

    images.forEach((img) => img.classList.add('lazy-reveal'));

    const imageObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;

          const img = entry.target as HTMLImageElement;
          img.classList.add('lazy-reveal', 'is-inview');

          if (img.complete) {
            img.classList.add('is-loaded');
          } else {
            img.addEventListener('load', () => img.classList.add('is-loaded'), { once: true });
          }

          imageObserver.unobserve(img);
        });
      },
      {
        threshold: 0.08,
        rootMargin: '80px 0px'
      }
    );

    images.forEach((img) => imageObserver.observe(img));
  };

  const setupNavbarScrollState = () => {
    const navbar = document.querySelector<HTMLElement>('[data-navbar]');
    if (!navbar) return;
    if (navbar.dataset.motionBound === 'true') {
      navbar.classList.toggle('is-scrolled', window.scrollY > 16);
      return;
    }

    const updateState = () => {
      const y = window.scrollY;
      navbar.classList.toggle('is-scrolled', y > 16);

      const isScrollingDown = y > lastScrollY;
      const shouldHide = isScrollingDown && y > 160;
      navbar.classList.toggle('is-hidden', shouldHide);
      lastScrollY = y;
    };

    updateState();
    window.addEventListener('scroll', updateState, { passive: true });
    navbar.dataset.motionBound = 'true';
  };

  const initMotion = () => {
    setupRevealSections();
    setupLazyImageReveal();
    setupNavbarScrollState();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMotion, { once: true });
  } else {
    initMotion();
  }

  document.addEventListener('astro:after-swap', initMotion);
</script>
