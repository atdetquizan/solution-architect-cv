---
interface Props {
  ownerName: string;
}

const { ownerName } = Astro.props;
const compactName = ownerName
  .split(' ')
  .slice(0, 2)
  .join(' ');
---

<header data-navbar class="fixed top-2 left-1/2 z-40 w-[min(96vw,76rem)] -translate-x-1/2 rounded-2xl border border-(--line) bg-[rgba(247,243,235,0.78)] px-3 py-3 backdrop-blur-md sm:top-3 sm:px-4 md:top-4 md:px-5">
  <nav class="flex items-center justify-between gap-3 sm:gap-4" aria-label="Navegacion principal">
    <a href="#hero" class="font-subtitle text-base tracking-wide text-(--text-primary) sm:text-lg">{compactName}</a>
    <ul class="hidden items-center gap-5 text-sm font-medium text-(--text-secondary) md:flex">
      <li><a href="#about" class="nav-link">Sobre mi</a></li>
      <li><a href="#skills" class="nav-link">Skills</a></li>
      <li><a href="#projects" class="nav-link">Proyectos</a></li>
      <li><a href="#contact" class="nav-link">Contacto</a></li>
    </ul>
    <a href="#contact" class="nav-cta text-xs font-semibold sm:text-sm">Hablemos</a>
  </nav>
  <ul class="no-scrollbar mt-3 flex items-center gap-2 overflow-x-auto pb-1 text-xs font-semibold tracking-wide text-(--text-secondary) md:hidden" aria-label="Enlaces de seccion">
    <li><a href="#about" class="nav-cta whitespace-nowrap px-3 py-1.5">Sobre mi</a></li>
    <li><a href="#skills" class="nav-cta whitespace-nowrap px-3 py-1.5">Skills</a></li>
    <li><a href="#experience" class="nav-cta whitespace-nowrap px-3 py-1.5">Experiencia</a></li>
    <li><a href="#projects" class="nav-cta whitespace-nowrap px-3 py-1.5">Proyectos</a></li>
    <li><a href="#contact" class="nav-cta whitespace-nowrap px-3 py-1.5">Contacto</a></li>
  </ul>
</header>
