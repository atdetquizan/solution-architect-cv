---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<span class="rounded-full border border-(--line-strong) bg-[color-mix(in_oklab,var(--accent-soft)_18%,transparent)] px-2 py-0.5 text-[0.69rem] font-medium tracking-wide text-(--text-primary) sm:px-2.5 sm:text-xs">
  {text}
</span>
